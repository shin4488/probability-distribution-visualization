    "format": "biome format --write ."
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@tailwindcss/vite": "4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "vitest": "3.2.6"
  }
}
